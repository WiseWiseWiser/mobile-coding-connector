#!/usr/bin/env bash
# Copy this file to local-debug-remote-exec.sh (gitignored) and set REMOTE_EXEC.
#
# Usage:
#   ./local-debug-remote-exec.sh echo yes
#   ./local-debug-remote-exec.sh grep -c pattern /root/some.log
#   ./local-debug-remote-exec.sh sh -c 'cd /root && pwd'

set -euo pipefail

# Non-interactive one-shot remote exec. Configure locally — not committed.
# REMOTE_EXEC is the argv prefix; remote command args are appended as "$@".
# If your tool needs a "--" separator before the remote command, include it here.
REMOTE_EXEC=()

if ((${#REMOTE_EXEC[@]} == 0)); then
  echo "Set REMOTE_EXEC in local-debug-remote-exec.sh (copy from local-debug-remote-exec.sh.example)" >&2
  exit 1
fi

if (($# == 0)); then
  echo "Usage: $0 <remote-command...>" >&2
  echo "Example: $0 echo yes" >&2
  echo "         $0 sh -c 'cd /root && pwd'" >&2
  exit 1
fi

# Use non-interactive remote exec — do not pipe into an interactive remote login
# (prompts consume stdin lines before your command runs).
exec "${REMOTE_EXEC[@]}" "$@"